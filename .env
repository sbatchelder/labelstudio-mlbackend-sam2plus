# --- Defaults shared by both compose files ----------------------------------
# Project-root .env: Docker Compose loads it automatically for variable
# interpolation, so the multi-target compose.yml needs no --env-file flag:
#   docker compose up -d brick ichthyolith
# For a single instance, add the target env on the CLI; this .env still loads
# automatically as the base, and the target overrides what it needs:
#   docker compose -f single-compose.yml --env-file envs/ichthyolith.env up -d --build

# Shared image built once by the sam2-build service and reused by each target
# (compose.yml only; single-compose.yml builds its own image).
SAM2_IMAGE=sam2plus:local

# Bake the SAM2 checkpoints into the image at build time. Default false: keep
# the image slim and let sam2-build download them into MODEL_STORE. Set true
# for a self-contained image -- then run WITHOUT a MODEL_STORE mount over
# /sam2/checkpoints, which would otherwise shadow the baked copies.
BAKE_CHECKPOINTS=false

# Basic auth for the ML backend server (blank = disabled)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Gunicorn process model
WORKERS=1
THREADS=8

# Compute device: cuda | cpu
DEVICE=cuda

# GPU device id on this host.
HOST_GPU=3

# SAM2 model config + checkpoint (filenames inside the checkpoint store)
MODEL_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml
MODEL_CHECKPOINT=sam2.1_hiera_large.pt

# Host directory holding the SAM2 checkpoints, shared by all instances and
# mounted read-only at /sam2/checkpoints. Populate it once before first `up`.
MODEL_STORE=./vols/model-store
