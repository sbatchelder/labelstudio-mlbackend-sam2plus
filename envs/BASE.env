# --- Defaults shared by both compose files ----------------------------------
# Used by compose.yml (single instance) and multi-compose.yml.
# Pass this file FIRST, then one target env file that overrides what it needs:
#   docker compose -f compose.yml --env-file envs/BASE.env --env-file envs/ichthyolith.env up -d --build
# Later --env-file values win, so the target env overrides anything set here.

# Shared image built once by the sam2-build service and reused by each target
# (multi-compose.yml only; compose.yml uses its own image).
SAM2_IMAGE=sam2plus:local

# Basic auth for the ML backend server (blank = disabled)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Gunicorn process model
WORKERS=1
THREADS=8

# Compute device: cuda | cpu
DEVICE=cuda

# GPU device id on this host.
HOST_GPU=0

# SAM2 model config + checkpoint (filenames inside the checkpoint store)
MODEL_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml
MODEL_CHECKPOINT=sam2.1_hiera_large.pt

# Host directory holding the SAM2 checkpoints, shared by all instances and
# mounted read-only at /sam2/checkpoints. Populate it once before first `up`.
MODEL_STORE=./data/model-store
