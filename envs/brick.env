# --- brick Label Studio instance --------------------------------------------
# Single-instance run:
#   docker compose -f compose.yml --env-file envs/SINGLE.env --env-file envs/brick.env up -d --build

# Distinct project name -- without this, a second single-instance `up` tears
# down the other instance because Compose treats them as the same project.
COMPOSE_PROJECT_NAME=sam2-brick

CONTAINER_NAME=SAM2Plus-brick
HOST_PORT=22203
HOST_GPU=0

# Per-instance data dirs -- kept separate so caches never cross tenants.
SERVER_DIR=./data/brick/server
CACHE_DIR=./data/brick/cache

LABEL_STUDIO_URL=https://labelstudio.brick.whoi.edu
LABEL_STUDIO_API_KEY=REDACTED
