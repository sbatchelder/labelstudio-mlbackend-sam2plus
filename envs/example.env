# --- example target instance (TEMPLATE) -------------------------------------
# Copy this file to envs/<your-target>.env and fill in the values below, then
# launch with envs/BASE.env first and your target file second:
#
#   docker compose -f compose.yml --env-file envs/BASE.env --env-file envs/<your-target>.env up -d --build
#
# Later --env-file values win, so anything you set here overrides envs/BASE.env.
# Only the values that differ from BASE.env need to be set.

# Distinct Compose project name -- without this, a second single-instance `up`
# tears down the other instance because Compose treats them as the same project.
COMPOSE_PROJECT_NAME=sam2-mytarget

# Container name (must be unique across instances on this host).
CONTAINER_NAME=SAM2Plus-mytarget

# Host port mapped to the container's 9090; pick one free per instance.
HOST_PORT=22204

# GPU device id on this host.
HOST_GPU=0

# Per-instance data dirs -- keep separate so image caches never cross tenants.
SERVER_DIR=./data/mytarget/server
CACHE_DIR=./data/mytarget/cache

# The Label Studio instance this backend serves. Use host.docker.internal (not
# localhost) if Label Studio runs on the host. Fill in your real API key; any
# non-empty value here is redacted on stage by the envsecrets clean filter (see
# README "Secret Redaction"), so it never reaches the public repo.
LABEL_STUDIO_URL=https://labelstudio.example.org
LABEL_STUDIO_API_KEY=
