# --- ichthyolith Label Studio instance --------------------------------------
# Single-instance run:
#   docker compose -f compose.yml --env-file envs/SINGLE.env --env-file envs/ichthyolith.env up -d --build

# Distinct project name -- without this, a second single-instance `up` tears
# down the other instance because Compose treats them as the same project.
COMPOSE_PROJECT_NAME=sam2-ichthyolith

CONTAINER_NAME=SAM2BigImg-ichthyolith
HOST_PORT=22202
HOST_GPU=0

# Per-instance data dirs -- kept separate so caches never cross tenants.
SERVER_DIR=./data/ichthyolith/server
CACHE_DIR=./data/ichthyolith/cache

LABEL_STUDIO_URL=https://ichthyolith.whoi.edu
LABEL_STUDIO_API_KEY=REDACTED
