# --- localhost test instance ------------------------------------------------
# A throwaway local backend for development and probe.py runs.
# Run (root .env loads automatically as the base):
#   docker compose -f single-compose.yml --env-file envs/localhost.env up -d --build
#
# Tuned so `python probe.py` works with no flags: probe defaults to
# http://localhost:22201 and seeds images into ./vols/cache, which is the
# CACHE_DIR mounted to the container's /cache below.

COMPOSE_PROJECT_NAME=sam2-localhost
CONTAINER_NAME=SAM2Plus-localhost
HOST_PORT=22201
HOST_GPU=0

# Verbose logs while developing.
LOG_LEVEL=DEBUG

# Reuse the repo's ./vols layout -- this is what probe.py's --cache-dir
# defaults to. Separate from the brick/ichthyolith data dirs.
SERVER_DIR=./vols/server
CACHE_DIR=./vols/cache

# probe.py pre-seeds images into the cache and never calls back to Label
# Studio, so these are unused by probe -- the placeholders just satisfy the
# compose required-var checks. Set real values only if you wire this backend
# to a local Label Studio (use host.docker.internal, not localhost, so the
# container can reach a Label Studio running on the host).
LABEL_STUDIO_URL=http://host.docker.internal:8080
LABEL_STUDIO_API_KEY=REDACTED
